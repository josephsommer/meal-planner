# ----------------------------------------------------------------------------
# Apache Maven Wrapper startup batch script, version 3.3.2
# ----------------------------------------------------------------------------

set -e

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

# Find the project base directory
find_maven_basedir() {
  WDIR="$1"
  while [ "$WDIR" != '/' ] ; do
    if [ -d "$WDIR"/.mvn ] ; then
      BASE_DIR="$WDIR"
      break
    fi
    WDIR=$(cd "$WDIR/.."; pwd)
  done
  echo "${BASE_DIR:-$1}"
}

BASE_DIR=$(find_maven_basedir "$(cd "$(dirname "$0")"; pwd)")

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$BASE_DIR}"

WRAPPER_LAUNCHER="org.apache.maven.wrapper.MavenWrapperMain"

# Download the wrapper jar if not present
DOWNLOAD_URL=$(sed -n 's/wrapperUrl=//p' "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_PROPERTIES")

if [ -r "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" ]; then
    :
elif [ -n "$DOWNLOAD_URL" ]; then
    if command -v wget > /dev/null 2>&1; then
        wget -q -O "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" "$DOWNLOAD_URL" || rm -f "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR"
    elif command -v curl > /dev/null 2>&1; then
        curl -o "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" "$DOWNLOAD_URL" || rm -f "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR"
    fi
fi

exec "$JAVA_HOME/bin/java" \
  -classpath "$MAVEN_PROJECTBASEDIR/$MAVEN_WRAPPER_JAR" \
  "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" \
  $MAVEN_OPTS \
  $WRAPPER_LAUNCHER "$@"
